generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum InventoryAdjustmentType {
  USE
  SALE
  DAMAGE
  LOSS
}

enum CookCategory {
  PASTRY
  BREAD
  HOT_FOOD
}

enum ChefOrderStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model User {
  id            String        @id @default(uuid())
  username      String        @unique
  password      String
  role          String        @default("USER")
  cookCategory  CookCategory?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Customer {
  id            String   @id @default(uuid()) @map("id")
  name          String   @map("name")
  email         String?  @unique @map("email")
  phone         String   @unique @map("phone")
  loyaltyPoints Int      @default(0)
  customerType  String   @default("NEW")
  createdAt     DateTime @default(now()) @map("createdat")
  orders        Order[]

  @@index([phone])
  @@map("customer")
}

model LoyaltyConfig {
  id                    String   @id @default(uuid())
  currencyCode          String   @default("LKR")
  currencySymbol        String   @default("Rs")
  pointsPerAmount       Float    @default(1)
  amountPerPoints       Float    @default(100)
  redeemThreshold       Int      @default(100)
  redeemDiscount        Float    @default(20)
  regularThreshold      Int      @default(50)
  loyalThreshold        Int      @default(200)
  vipThreshold          Int      @default(500)
  updatedAt             DateTime @updatedAt
  updatedBy             String?
}

model Product {
  id              String        @id @default(uuid())
  name            String
  description     String?
  sku             String?       @unique
  price           Float
  unit            String        @default("piece")
  stockQty        Int           @default(0)
  lowStockThreshold Int         @default(0)
  imageUrl        String?
  isAvailable     Boolean       @default(true)
  requiresCooking Boolean       @default(false)
  cookCategory    CookCategory?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orderItems      OrderItem[]
  chefOrders      ChefOrder[]
  recipeItems     RecipeItem[]
}

model Chef {
  id     String @id @default(uuid())
  name   String
  status String @default("AVAILABLE")
}

model Order {
  id            String      @id @default(uuid())
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  subtotal      Float
  discount      Float       @default(0)
  total         Float
  paymentMethod String
  status        String      @default("PAID")
  txRef         String?
  createdAt     DateTime    @default(now())
  items         OrderItem[]
  chefOrders    ChefOrder[]
}

model OrderItem {
  id             String      @id @default(uuid())
  orderId        String
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  quantity       Int
  price          Float
  assignedChefId String?
  chefOrders     ChefOrder[]
}

model ChefOrder {
  id           String          @id @default(uuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id])
  orderItemId  String
  orderItem    OrderItem       @relation(fields: [orderItemId], references: [id])
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  cookCategory CookCategory
  status       ChefOrderStatus @default(PENDING)
  acceptedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([cookCategory, status])
  @@index([orderId])
}

// ── Inventory ─────────────────────────────────────────────────────────────────

model InventoryItem {
  id               String          @id @default(uuid())
  name             String          @unique
  category         String
  unit             String
  isPerishable     Boolean         @default(false)
  minReorderLevel  Float           @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  batches          InventoryBatch[]
  recipeItems      RecipeItem[]
}

model InventoryBatch {
  id             String       @id @default(uuid())
  itemId         String
  item           InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  lotNumber      String?
  quantity       Float        @default(0)
  unitCost       Float?
  expirationDate DateTime?
  receivedAt     DateTime     @default(now())
  adjustments    InventoryAdjustment[]

  @@index([itemId])
}

model InventoryAdjustment {
  id        String                  @id @default(uuid())
  batchId   String
  batch     InventoryBatch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type      InventoryAdjustmentType
  quantity  Float
  reason    String?
  cost      Float?
  createdAt DateTime                @default(now())

  @@index([batchId])
}

model RecipeItem {
  id              String        @id @default(uuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantityPerUnit Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([productId, inventoryItemId])
  @@index([productId])
}

// ── Equipment ─────────────────────────────────────────────────────────────────

model Equipment {
  id                      String                @id @default(uuid())
  name                    String
  serialNumber            String?
  purchaseDate            DateTime?
  warrantyExpiryDate      DateTime?
  maintenanceIntervalDays Int?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  maintenances            EquipmentMaintenance[]
}

model EquipmentMaintenance {
  id           String    @id @default(uuid())
  equipmentId  String
  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  performedAt  DateTime  @default(now())
  description  String?
  cost         Float?
  nextDueDate  DateTime?
  createdAt    DateTime  @default(now())

  @@index([equipmentId])
}
