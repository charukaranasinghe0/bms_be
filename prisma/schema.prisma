generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CookCategory {
  PASTRY
  BREAD
  HOT_FOOD
}

enum ChefOrderStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum LoyaltyTxType {
  EARNED
  REDEEMED
  ADJUSTED
}

model LoyaltyTier {
  id               String   @id @default(uuid())
  name             String   @unique
  minPoints        Int      @map("min_points")
  maxPoints        Int?     @map("max_points")        // null = open-ended top tier
  pointMultiplier  Decimal  @map("point_multiplier") @db.Decimal(5, 2)
  perksConfig      Json     @default("{}") @map("perks_config")
  sortOrder        Int      @map("sort_order")        // ascending, drives range ordering
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([minPoints])
  @@map("loyalty_tiers")
}

model LoyaltySettings {
  id                   String   @id @default(uuid())
  pointsPerCurrencyUnit Decimal @map("points_per_currency_unit") @db.Decimal(5, 2)
  redemptionThreshold  Int      @map("redemption_threshold")     // points needed per redemption block
  redemptionValue      Decimal  @map("redemption_value") @db.Decimal(10, 2) // currency value per block
  currencyCode         String   @default("USD") @map("currency_code")
  currencySymbol       String   @default("$") @map("currency_symbol")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("loyalty_settings")
}

model User {
  id            String        @id @default(uuid())
  username      String        @unique
  password      String
  role          String        @default("USER")
  cookCategory  CookCategory?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model Customer {
  id             String      @id @default(uuid()) @map("id")
  name           String      @map("name")
  email          String?     @unique @map("email")
  phone          String      @unique @map("phone")
  currentPoints  Int         @default(0) @map("current_points")
  lifetimePoints Int         @default(0) @map("lifetime_points")
  tierName       String      @default("") @map("tier_name")  // dynamic — matches LoyaltyTier.name
  createdAt      DateTime    @default(now()) @map("createdat")
  orders         Order[]
  loyaltyTxs     LoyaltyPointTransaction[]

  @@index([phone])
  @@map("customer")
}

model LoyaltyPointTransaction {
  id         String        @id @default(uuid())
  customerId String        @map("customer_id")
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       LoyaltyTxType
  points     Int           // positive = earned/adjusted-up, negative = redeemed/adjusted-down
  orderId    String?       @map("order_id")
  note       String?
  createdAt  DateTime      @default(now()) @map("created_at")

  @@index([customerId])
  @@index([orderId])
  @@map("loyalty_point_transactions")
}

model Product {
  id              String        @id @default(uuid())
  name            String
  description     String?
  sku             String?       @unique
  price           Float
  unit            String        @default("piece")
  stockQty        Int           @default(0)
  lowStockThreshold Int         @default(0)
  imageUrl        String?
  isAvailable     Boolean       @default(true)
  requiresCooking Boolean       @default(false)
  cookCategory    CookCategory?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  orderItems      OrderItem[]
  chefOrders      ChefOrder[]
}

model Chef {
  id     String @id @default(uuid())
  name   String
  status String @default("AVAILABLE")
}

model Order {
  id            String      @id @default(uuid())
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  subtotal      Float
  discount      Float       @default(0)
  total         Float
  paymentMethod String
  status        String      @default("PAID")
  txRef         String?
  createdAt     DateTime    @default(now())
  items         OrderItem[]
  chefOrders    ChefOrder[]
}

model OrderItem {
  id             String      @id @default(uuid())
  orderId        String
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product     @relation(fields: [productId], references: [id])
  quantity       Int
  price          Float
  assignedChefId String?
  chefOrders     ChefOrder[]
}

model ChefOrder {
  id           String          @id @default(uuid())
  orderId      String
  order        Order           @relation(fields: [orderId], references: [id])
  orderItemId  String
  orderItem    OrderItem       @relation(fields: [orderItemId], references: [id])
  productId    String
  product      Product         @relation(fields: [productId], references: [id])
  cookCategory CookCategory
  status       ChefOrderStatus @default(PENDING)
  acceptedAt   DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())

  @@index([cookCategory, status])
  @@index([orderId])
}
