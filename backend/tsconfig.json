{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["node", "express"]
  },
  "include": [
    "server.ts",
    "app.ts",
    "model",
    "controller",
    "repository",
    "service",
    "routes",
    "middlewares",
    "utils",
    "config",
    "db",
    "prisma"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
